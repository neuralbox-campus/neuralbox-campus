# ============================================================
# NeuralBox Campus IA — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── DATABASE ────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/neuralbox_campus"

# ─── AUTH ────────────────────────────────────────────────────
JWT_SECRET="CHANGE-THIS-to-a-random-64-char-string"
JWT_REFRESH_SECRET="CHANGE-THIS-to-another-random-64-char-string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
BCRYPT_ROUNDS=12

# ─── APP ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
API_URL="http://localhost:3001"

# ─── EMAIL (Resend) ─────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="NeuralBox Campus <campus@neuralboxai.com>"

# ─── PAYMENTS: Wompi (Colombia) ─────────────────────────────
WOMPI_PUBLIC_KEY="pub_test_xxxxxxxxxxxx"
WOMPI_PRIVATE_KEY="prv_test_xxxxxxxxxxxx"
WOMPI_EVENTS_SECRET="test_events_xxxxxxxxxxxx"
WOMPI_ENV="sandbox"  # sandbox | production

# ─── PAYMENTS: MercadoPago (LATAM) ──────────────────────────
MP_ACCESS_TOKEN="TEST-xxxxxxxxxxxx"
MP_PUBLIC_KEY="TEST-xxxxxxxxxxxx"
MP_WEBHOOK_SECRET="xxxxxxxxxxxx"

# ─── PAYMENTS: PayPal (International) ───────────────────────
PAYPAL_CLIENT_ID="xxxxxxxxxxxx"
PAYPAL_CLIENT_SECRET="xxxxxxxxxxxx"
PAYPAL_ENV="sandbox"  # sandbox | live

# ─── PAYMENTS: CryptAPI (Crypto) ────────────────────────────
CRYPTAPI_CALLBACK_URL="https://campus.neuralboxai.com/api/webhooks/crypto"
CRYPTO_WALLET_BTC="your-btc-wallet-address"
CRYPTO_WALLET_ETH="your-eth-wallet-address"
CRYPTO_WALLET_USDT_TRC20="your-usdt-trc20-wallet-address"

# ─── VIDEO CDN (Bunny Stream) ───────────────────────────────
BUNNY_API_KEY="xxxxxxxxxxxx"
BUNNY_LIBRARY_ID="xxxxxxxxxxxx"
BUNNY_CDN_HOSTNAME="xxxxxxxxxxxx.b-cdn.net"
BUNNY_TOKEN_KEY="xxxxxxxxxxxx"  # For signed URLs

# ─── MONITORING ──────────────────────────────────────────────
SENTRY_DSN=""
